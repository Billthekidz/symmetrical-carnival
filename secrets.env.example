# /etc/polymarket-watcher/secrets.env
# ------------------------------------------------------------
# Runtime secrets for the Polymarket Watcher service.
#
# Install as:
#   sudo install -o root -g polymarket-watcher -m 0640 \
#       secrets.env.example /etc/polymarket-watcher/secrets.env
#
# Then populate the values below.  Do NOT commit the populated
# file to version control.
# ------------------------------------------------------------

# Discord incoming webhook URL (outbound alerts only).
# Obtain it from: Discord channel → Edit channel → Integrations → Webhooks
# Leave blank or omit this file entirely if Discord alerts are disabled
# in config.yaml (actions.discord.enabled: false).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
